# Discord - REUSE your existing bot token (Application ID 1505924516587638876),
# the same one Job Board / June Games / Daily Accountability / Call Reviews
# already log in with. Do NOT create a new Discord application - just make
# sure that existing bot has been invited to whatever channel you use for
# pasting transcripts below.
DISCORD_BOT_TOKEN=
DISCORD_CALL_REVIEW_DRAFTS_CHANNEL_ID=

# This service's OWN Postgres (new Railway project, isolated from your others).
# Holds transcripts, drafts, edits, lessons, examples.
DATABASE_URL=

# Anthropic
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-5

# Portal (Lovable Cloud, dialled.online)
PORTAL_BASE_URL=https://dialled.online

# The EXISTING dialled-call-reviews service. This service calls its REST API
# directly - GET /api/students to read the roster, POST /api/review-complete
# to hand off a finished review. No direct database access needed or used.
CALL_REVIEW_SERVICE_BASE_URL=
# Same value as that service's own PORTAL_API_KEY env var - it checks this
# against the x-api-key header on every request.
CALL_REVIEW_SERVICE_API_KEY=

# Shared secret so the Lovable portal <-> this service can verify requests
# aren't forged. Unrelated to CALL_REVIEW_SERVICE_API_KEY above - this one's
# just between the portal and this service.
INTERNAL_WEBHOOK_SECRET=

PORT=3000
